# ================================================================
# PEKE-ARI — Variables de entorno
# Copia este archivo como ".env" y completa tus propios valores.
# NUNCA subas el archivo ".env" real a un repositorio público.
# ================================================================

# Puerto en el que corre el servidor
PORT=3000

# Entorno: "production" activa cabeceras/cookies estrictas (HTTPS)
NODE_ENV=production

# URL pública del sitio (usada por CSP y por el enlace canónico)
SITE_URL=https://www.pekeari.com

# --- Google reCAPTCHA v3 ---
# Crea tus claves en https://www.google.com/recaptcha/admin
# Si las dejas vacías, el sistema NO bloquea el formulario, pero
# tampoco valida el puntaje anti-spam (modo degradado, solo para
# desarrollo local).
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- Sal para anonimizar IPs en las estadísticas ---
# Cambia este valor por una cadena aleatoria propia. Se usa para
# generar un hash irreversible de cada IP (no se guarda la IP real).
IP_HASH_SALT=cambia-esta-clave-por-una-aleatoria-larga

# --- Acceso al panel de estadísticas (login.html) ---
# Cambia el usuario y, sobre todo, la contraseña, por unos propios.
# Nunca se guardan en el código: solo viven aquí, en el servidor.
ADMIN_USER=admin
ADMIN_PASSWORD=CambiaEstaContraseñaSegura123

# Secreto usado para firmar la cookie de sesión del login. Cambia
# este valor por una cadena aleatoria larga y única (por ejemplo,
# generada con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=cambia-este-secreto-por-uno-aleatorio-y-largo

# --- Rate limiting del formulario de contacto ---
CONTACT_RATE_LIMIT_WINDOW_MIN=10
CONTACT_RATE_LIMIT_MAX=5

# --- Correo de destino del formulario de contacto (opcional) ---
# Si tu hosting soporta un proveedor SMTP, agrega aquí tus datos y
# conecta server/routes/contacto.js con tu proveedor preferido
# (Nodemailer, Resend, SendGrid, etc.)
CONTACT_DESTINATION_EMAIL=contacto@pekeari.com
